# Google OAuth2 Client ID
# 1. https://console.cloud.google.com 에서 프로젝트 생성
# 2. APIs & Services > Credentials > OAuth 2.0 Client IDs 생성
# 3. Authorized JavaScript origins에 http://localhost:5173 추가
VITE_GOOGLE_CLIENT_ID=

# Toss Payments (토스페이먼츠)
# https://developers.tosspayments.com 에서 클라이언트 키 발급
VITE_TOSS_CLIENT_KEY=test_ck_your_toss_client_key_here

# Stripe (해외 결제 옵션)
# https://dashboard.stripe.com/apikeys 에서 Publishable key 발급
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key_here

# App URL (배포 시 변경)
VITE_APP_URL=http://localhost:5173
